<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Middle layer: wrap_content height forces square via spacer -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical">

        <!-- Invisible 1:1 spacer: height = width -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@drawable/spacer_square"
            android:visibility="invisible"
            android:importantForAccessibility="no" />

        <!-- Actual visible content (square) -->
        <FrameLayout
            android:id="@+id/widget_friend_post_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="0dp"
            android:clipChildren="true"
            android:clipToPadding="true"
            android:background="@drawable/widget_background">

            <!-- Friend post image (square, centered) -->
            <ImageView
                android:id="@+id/friend_post_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adjustViewBounds="false"
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <!-- Text content container (when no image) -->
            <LinearLayout
                android:id="@+id/friend_post_text_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/friend_post_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:maxLines="5"
                    android:ellipsize="end"
                    android:textSize="11sp"
                    android:textColor="#333333"
                    android:lineSpacingMultiplier="1.1" />
            </LinearLayout>

            <!-- Single emoji (mood or battery) centered for check-in updates -->
            <TextView
                android:id="@+id/checkin_single_emoji"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textSize="64sp"
                android:visibility="gone" />

            <!-- Empty state (no updates from friends) -->
            <TextView
                android:id="@+id/friend_post_empty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:padding="12dp"
                android:text="No updates from\nfriends yet :)"
                android:textSize="11sp"
                android:textColor="#888888"
                android:textAlignment="center"
                android:visibility="visible" />

            <!-- Friend profile image top-right, circular -->
            <ImageView
                android:id="@+id/friend_post_author_image"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="top|end"
                android:layout_marginEnd="10dp"
                android:layout_marginTop="10dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="Friend Profile" />

        </FrameLayout>
    </FrameLayout>
</FrameLayout>
