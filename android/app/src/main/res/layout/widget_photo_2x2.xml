<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_friend_post_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="0dp"
    android:background="@drawable/widget_background">

    <!-- Friend post image (fills entire widget when present) -->
    <ImageView
        android:id="@+id/friend_post_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <!-- Text content container (when no image) -->
    <LinearLayout
        android:id="@+id/friend_post_text_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/friend_post_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:maxLines="5"
            android:ellipsize="end"
            android:textSize="11sp"
            android:textColor="#333333"
            android:lineSpacingMultiplier="1.1" />
    </LinearLayout>

    <!-- Empty state (no updates from friends) -->
    <TextView
        android:id="@+id/friend_post_empty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:padding="12dp"
        android:text="No updates from\nfriends yet :)"
        android:textSize="11sp"
        android:textColor="#888888"
        android:textAlignment="center"
        android:visibility="visible" />

    <!-- Friend profile image top-right, circular -->
    <ImageView
        android:id="@+id/friend_post_author_image"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="top|end"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="8dp"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:contentDescription="Friend Profile" />

</FrameLayout>
