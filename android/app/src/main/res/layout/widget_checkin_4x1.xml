<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Inner container is wrap_content + vertical center, so the visible widget
         shrinks to its content height even when the launcher allocates a taller row -->
    <LinearLayout
        android:id="@+id/widget_checkin_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:orientation="vertical"
        android:background="@drawable/widget_background"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="10dp"
        android:paddingBottom="12dp">

    <!-- Row of 4 buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_horizontal"
        android:baselineAligned="false">

        <!-- I feel Button (left-aligned in column so it lines up with the title) -->
        <LinearLayout
            android:id="@+id/btn_i_feel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="start"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:paddingTop="0dp"
            android:paddingBottom="2dp">

            <FrameLayout
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:background="@drawable/widget_emoji_button_bg">

                <TextView
                    android:id="@+id/i_feel_emoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="+"
                    android:textSize="32sp"
                    android:textColor="#888888" />
            </FrameLayout>
        </LinearLayout>

        <!-- My Battery Button -->
        <LinearLayout
            android:id="@+id/btn_my_battery"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:paddingTop="0dp"
            android:paddingBottom="2dp">

            <FrameLayout
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:background="@drawable/widget_emoji_button_bg">

                <TextView
                    android:id="@+id/my_battery_emoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="+"
                    android:textSize="32sp"
                    android:textColor="#888888" />
            </FrameLayout>
        </LinearLayout>

        <!-- My Music Button -->
        <LinearLayout
            android:id="@+id/btn_my_music"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:paddingTop="0dp"
            android:paddingBottom="2dp">

            <FrameLayout
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:background="@drawable/widget_emoji_button_bg">

                <ImageView
                    android:id="@+id/my_music_album"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone"
                    android:scaleType="centerCrop" />

                <TextView
                    android:id="@+id/my_music_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="+"
                    android:textSize="32sp"
                    android:textColor="#888888" />

                <!-- Spotify/Playlist icon top-left of My Music box -->
                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_gravity="top|start"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="4dp"
                    android:src="@drawable/ic_playlist"
                    android:contentDescription="Music" />
            </FrameLayout>
        </LinearLayout>

        <!-- My Thought Button (right-aligned in column for symmetry with first cell) -->
        <LinearLayout
            android:id="@+id/btn_my_thought"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="end"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:paddingTop="0dp"
            android:paddingBottom="2dp">

            <FrameLayout
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:background="@drawable/widget_emoji_button_bg">

                <!-- Plus sign shown when description is empty -->
                <TextView
                    android:id="@+id/my_thought_plus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="+"
                    android:textSize="32sp"
                    android:textColor="#888888" />

                <!-- Description text shown when non-empty (3 lines, top-left) -->
                <TextView
                    android:id="@+id/my_thought_description"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="top|start"
                    android:gravity="top|start"
                    android:padding="6dp"
                    android:maxLines="3"
                    android:ellipsize="end"
                    android:textSize="11sp"
                    android:textColor="#BF000000"
                    android:includeFontPadding="false"
                    android:lineSpacingMultiplier="0.95"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>
    </LinearLayout>
</FrameLayout>
