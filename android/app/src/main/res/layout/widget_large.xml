<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <!-- SECTION: Whoami Updates (fixed min height like iOS) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="100dp"
        android:orientation="vertical">

        <!-- Section Header (title + refresh button, same as iOS) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/icon_whoami_updates"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Whoami updates"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginStart="6dp" />

            <!-- Spacer: RemoteViews only supports specific views (TextView, ImageView, etc.), not generic View -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/widget_refresh_button"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_widget_refresh"
                android:scaleType="fitCenter"
                android:contentDescription="Refresh widget" />
        </LinearLayout>

        <!-- Action Buttons + Friends Row (flex-start: items aligned to start) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical|start">

            <!-- I feel Button -->
            <LinearLayout
                android:id="@+id/btn_i_feel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp">

                <FrameLayout
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/widget_emoji_button_bg">

                    <TextView
                        android:id="@+id/i_feel_emoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="🤔"
                        android:textSize="24sp" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="I feel"
                    android:textSize="10sp"
                    android:textColor="#333333"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- My Battery Button -->
            <LinearLayout
                android:id="@+id/btn_my_battery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp">

                <FrameLayout
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/widget_emoji_button_bg">

                    <TextView
                        android:id="@+id/my_battery_emoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="🪫"
                        android:textSize="24sp" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="My Battery"
                    android:textSize="10sp"
                    android:textColor="#333333"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- My Music Button -->
            <LinearLayout
                android:id="@+id/btn_my_music"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp">

                <FrameLayout
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/widget_emoji_button_bg">

                    <ImageView
                        android:id="@+id/my_music_album"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:visibility="gone"
                        android:scaleType="centerCrop" />

                    <TextView
                        android:id="@+id/my_music_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="🎵"
                        android:textSize="24sp" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="My Music"
                    android:textSize="10sp"
                    android:textColor="#333333"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Friend 1 -->
            <LinearLayout
                android:id="@+id/friend_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp">

                <FrameLayout
                    android:layout_width="50dp"
                    android:layout_height="50dp">

                    <ImageView
                        android:id="@+id/friend_1_avatar"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@drawable/widget_avatar_bg"
                        android:scaleType="centerCrop" />

                    <!-- Blue update dot (ImageView: View not allowed in app widget) -->
                    <ImageView
                        android:id="@+id/friend_1_dot"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_gravity="top|end"
                        android:src="@drawable/widget_update_dot"
                        android:scaleType="fitCenter" />
                </FrameLayout>

                <TextView
                    android:id="@+id/friend_1_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Friend1"
                    android:textSize="10sp"
                    android:textColor="#333333"
                    android:layout_marginTop="4dp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <!-- Friend 2 -->
            <LinearLayout
                android:id="@+id/friend_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp">

                <FrameLayout
                    android:layout_width="50dp"
                    android:layout_height="50dp">

                    <ImageView
                        android:id="@+id/friend_2_avatar"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@drawable/widget_avatar_bg"
                        android:scaleType="centerCrop" />

                    <!-- Blue update dot (ImageView: View not allowed in app widget) -->
                    <ImageView
                        android:id="@+id/friend_2_dot"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_gravity="top|end"
                        android:src="@drawable/widget_update_dot"
                        android:scaleType="fitCenter" />
                </FrameLayout>

                <TextView
                    android:id="@+id/friend_2_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Friend2"
                    android:textSize="10sp"
                    android:textColor="#333333"
                    android:layout_marginTop="4dp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

    <!-- Divider (LinearLayout: View not allowed in app widget) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp" />

    <!-- SECTION: Shared Playlist -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="80dp"
        android:orientation="vertical">

        <!-- Section Header -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/icon_playlist"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shared Playlist"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <!-- Empty state: show when no playlists -->
        <TextView
            android:id="@+id/playlist_empty_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No playlists yet"
            android:textSize="13sp"
            android:textColor="#888888"
            android:visibility="gone" />

        <!-- Playlist Covers Row (hidden when empty) -->
        <LinearLayout
            android:id="@+id/playlist_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Playlist 1 with profile overlay -->
            <FrameLayout
                android:id="@+id/playlist_1_container"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_margin="4dp">

                <ImageView
                    android:id="@+id/playlist_1_album"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/widget_playlist_bg"
                    android:scaleType="centerCrop" />

                <ImageView
                    android:id="@+id/playlist_1_profile"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="2dp"
                    android:background="@drawable/widget_avatar_bg"
                    android:scaleType="centerCrop" />
            </FrameLayout>

            <!-- Playlist 2 with profile overlay -->
            <FrameLayout
                android:id="@+id/playlist_2_container"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_margin="4dp">

                <ImageView
                    android:id="@+id/playlist_2_album"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/widget_playlist_bg"
                    android:scaleType="centerCrop" />

                <ImageView
                    android:id="@+id/playlist_2_profile"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="2dp"
                    android:background="@drawable/widget_avatar_bg"
                    android:scaleType="centerCrop" />
            </FrameLayout>

            <!-- Playlist 3 with profile overlay -->
            <FrameLayout
                android:id="@+id/playlist_3_container"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_margin="4dp">

                <ImageView
                    android:id="@+id/playlist_3_album"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/widget_playlist_bg"
                    android:scaleType="centerCrop" />

                <ImageView
                    android:id="@+id/playlist_3_profile"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="2dp"
                    android:background="@drawable/widget_avatar_bg"
                    android:scaleType="centerCrop" />
            </FrameLayout>

            <!-- Playlist 4 with profile overlay -->
            <FrameLayout
                android:id="@+id/playlist_4_container"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_margin="4dp">

                <ImageView
                    android:id="@+id/playlist_4_album"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/widget_playlist_bg"
                    android:scaleType="centerCrop" />

                <ImageView
                    android:id="@+id/playlist_4_profile"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="2dp"
                    android:background="@drawable/widget_avatar_bg"
                    android:scaleType="centerCrop" />
            </FrameLayout>

            <!-- Playlist 5 with profile overlay -->
            <FrameLayout
                android:id="@+id/playlist_5_container"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_margin="4dp">

                <ImageView
                    android:id="@+id/playlist_5_album"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/widget_playlist_bg"
                    android:scaleType="centerCrop" />

                <ImageView
                    android:id="@+id/playlist_5_profile"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="2dp"
                    android:background="@drawable/widget_avatar_bg"
                    android:scaleType="centerCrop" />
            </FrameLayout>

        </LinearLayout>
    </LinearLayout>

    <!-- Divider (LinearLayout: View not allowed in app widget) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp" />

    <!-- SECTION: Question of the Day (60dp; 2 lines) -->
    <LinearLayout
        android:id="@+id/question_card"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_question_card_bg"
        android:padding="10dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/icon_question"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/question_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:text="What was a funny thing that happened today?"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginStart="2dp" />

    </LinearLayout>

</LinearLayout>
