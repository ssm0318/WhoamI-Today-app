<manifest
  xmlns:android="http://schemas.android.com/apk/res/android"
  package="com.whoami.today.app">
  <uses-permission android:name="com.google.android.gms.permission.AD_ID" />

  <uses-permission android:name="android.permission.INTERNET" />

  <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

  <uses-permission android:name="android.permission.CAMERA" />

  <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />


  <application
    android:name=".MainApplication"
    android:label="@string/app_name"
    android:icon="@mipmap/ic_launcher"
    android:roundIcon="@mipmap/ic_launcher_round"
    android:allowBackup="false"
    android:theme="@style/BootTheme">
    <receiver
        android:name="com.facebook.react.devsupport.DevSettingsActivity$DevSettingsReceiver"
        android:exported="false" />
    <receiver
        android:name="com.facebook.react.modules.notifications.RNPushNotificationReceiver"
        android:exported="false" />
    <receiver
        android:name="com.facebook.react.modules.notifications.RNPushNotificationBootEventReceiver"
        android:exported="false">
        <intent-filter>
            <action android:name="android.intent.action.BOOT_COMPLETED" />
        </intent-filter>
    </receiver>
    <activity
      android:name=".MainActivity"
      android:label="@string/app_name"
      android:configChanges="keyboard|keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
      android:launchMode="singleTask"
      android:windowSoftInputMode="adjustPan"
      android:screenOrientation="portrait"
      android:exported="true"
      android:theme="@style/BootTheme">
      <intent-filter>
        <action android:name="android.intent.action.MAIN" />
        <category android:name="android.intent.category.LAUNCHER" />
      </intent-filter>
      <intent-filter>
        <action android:name="android.intent.action.VIEW" />
        <category android:name="android.intent.category.DEFAULT" />
        <category android:name="android.intent.category.BROWSABLE" />
        <data android:scheme="whoami" android:host="app" />
      </intent-filter>
      <!-- App Links for HTTPS URLs -->
      <intent-filter android:autoVerify="true">
        <action android:name="android.intent.action.VIEW" />
        <category android:name="android.intent.category.DEFAULT" />
        <category android:name="android.intent.category.BROWSABLE" />
        <data
          android:scheme="https"
          android:host="whoami-admin-group.gina-park.site" />
      </intent-filter>
    </activity>

    <!-- Widget Provider -->
    <receiver
        android:name=".widget.WhoAmIWidgetProvider"
        android:exported="true"
        android:label="WhoAmI Today">
        <intent-filter>
            <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            <action android:name="com.whoami.today.app.WIDGET_UPDATE" />
            <action android:name="com.whoami.today.app.WIDGET_REFRESH" />
        </intent-filter>
        <meta-data
            android:name="android.appwidget.provider"
            android:resource="@xml/widget_info_large" />
    </receiver>

    <!-- Widget Update Service: runs as foreground when started from background (Android 12+) -->
    <service
        android:name=".widget.WidgetUpdateService"
        android:exported="false"
        android:foregroundServiceType="dataSync" />

    <!-- Widget midnight refresh: alarm fires at start of next day to refresh widget data -->
    <receiver
        android:name=".widget.WidgetMidnightReceiver"
        android:exported="false">
        <intent-filter>
            <action android:name="com.whoami.today.app.WIDGET_MIDNIGHT_REFRESH" />
        </intent-filter>
    </receiver>
  </application>
</manifest>
