    <receiver
        android:name=".widget.WhoAmIWidgetProvider_DEPRECATED"
        android:exported="true"
        android:label="WhoAmI Today">
        <intent-filter>
            <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            <action android:name="com.whoami.today.app.WIDGET_UPDATE" />
            <action android:name="com.whoami.today.app.WIDGET_REFRESH" />
        </intent-filter>
        <meta-data
            android:name="android.appwidget.provider"
