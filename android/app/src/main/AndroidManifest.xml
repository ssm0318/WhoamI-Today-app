    <!-- ================================================================= -->
    <!-- NEW WIDGETS - Feb 2026                                            -->
    <!-- ================================================================= -->

    <!-- Friend Update Widget (2x2) - Shows a random friend's latest post or check-in update -->
    <receiver
        android:name=".widget.PhotoWidgetProvider"
        android:exported="true"
        android:label="Friend Update Widget">
        <intent-filter>
            <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            <action android:name="com.whoami.today.app.WIDGET_UPDATE" />
        </intent-filter>
        <meta-data
            android:name="android.appwidget.provider"
            android:resource="@xml/widget_info_photo_2x2" />
    </receiver>

    <!-- Album Cover Widget (2x2) - Shows check-in album cover -->
    <receiver
        android:name=".widget.AlbumCoverWidgetProvider"
        android:exported="true"
        android:label="WhoAmI Album">
        <intent-filter>
            <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            <action android:name="com.whoami.today.app.WIDGET_UPDATE" />
        </intent-filter>
        <meta-data
            android:name="android.appwidget.provider"
            android:resource="@xml/widget_info_album_2x2" />
    </receiver>

    <!-- Check-in Widget (4x1) - Quick check-in access -->
    <receiver
        android:name=".widget.CheckinWidgetProvider"
        android:exported="true"
        android:label="WhoAmI Check-in">
        <intent-filter>
            <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            <action android:name="com.whoami.today.app.WIDGET_UPDATE" />
        </intent-filter>
        <meta-data
            android:name="android.appwidget.provider"
            android:resource="@xml/widget_info_checkin_4x1" />
    </receiver>

  </application>
</manifest>
