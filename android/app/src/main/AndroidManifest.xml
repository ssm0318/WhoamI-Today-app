        android:exported="false"
        android:foregroundServiceType="dataSync" />

    <receiver
        android:name=".widget.WidgetMidnightReceiver_DEPRECATED"
        android:exported="false">
        <intent-filter>
            <action android:name="com.whoami.today.app.WIDGET_MIDNIGHT_REFRESH" />
        </intent-filter>
    </receiver>
